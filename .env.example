# ─── Medicaid Dashboard Environment Variables ───────────────────
# Copy this file to .env and fill in your values.
# None of these are required to run the dashboard with sample data.
# They're needed for the data pipeline to pull live data.

# Socrata API App Token (optional, but recommended)
# Get one free at: https://data.medicaid.gov/profile/edit/developer_settings
# Without it, you're limited to ~1000 API requests/hour.
# With it, you get higher rate limits.
SOCRATA_APP_TOKEN=

# Anthropic API Key (required for AI-generated briefings)
# Get one at: https://console.anthropic.com/
# This powers the state briefing generation and natural language query features.
ANTHROPIC_API_KEY=

# Log level for the data pipeline (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ─── Site Password Protection ───────────────────────────────────
# Required in production to gate the dashboard behind a login page.

# The shared password visitors must enter to view the dashboard.
# Pick something memorable but not easy to guess. Share it only with
# the people you want to see the site.
DASHBOARD_PASSWORD=

# A long random string used to sign session cookies.
# Generate one by running:  openssl rand -base64 32
# If this value ever changes, everyone is logged out — that's how you
# force a global sign-out (e.g. if the password leaks).
SESSION_SECRET=
